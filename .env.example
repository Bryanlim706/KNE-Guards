# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Load into your shell before launching the server:
#   set -a; source .env; set +a
#   python -m kne_guards.server

# --- AI provider (at least one) ---
# OpenAI (preferred if both are set). Get a key at https://platform.openai.com/
OPENAI_API_KEY=
# Anthropic fallback. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Supabase ---
# Dashboard → Settings → API → Project URL
SUPABASE_URL=
# Dashboard → Settings → API → anon / publishable key (safe to expose to the browser)
SUPABASE_ANON_KEY=
# Dashboard → Settings → API → JWT Settings → JWT Secret (KEEP PRIVATE — signs access tokens)
SUPABASE_JWT_SECRET=
# Dashboard → Settings → Database → Connection string (use the pooler URL, port 6543)
SUPABASE_DB_URL=
